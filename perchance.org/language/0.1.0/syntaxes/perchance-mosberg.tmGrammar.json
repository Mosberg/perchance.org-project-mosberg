{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Perchance (Mosberg Advanced)",
  "scopeName": "source.perchance",
  "fileTypes": ["perchance", "pch", "txt"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#function-definition" },
    { "include": "#assignment-line" },
    { "include": "#list-definition" },
    { "include": "#list-item" },
    { "include": "#html-script" },
    { "include": "#html" },
    { "include": "#square-expression" },
    { "include": "#curly-expression" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.perchance", "match": "^\\s*#.*$" },
        { "name": "comment.line.double-slash.perchance", "match": "^\\s*//.*$" }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "name": "meta.function.definition.perchance",
          "begin": "^(\\$[A-Za-z_][\\w$]*)(\\s*)(\\()",
          "beginCaptures": {
            "1": { "name": "entity.name.function.perchance" },
            "3": { "name": "punctuation.definition.parameters.begin.perchance" }
          },
          "end": "$",
          "patterns": [
            { "name": "variable.parameter.perchance", "match": "\\b[A-Za-z_][\\w$]*\\b" },
            { "name": "punctuation.definition.parameters.end.perchance", "match": "\\)" },
            { "name": "storage.type.function.arrow.perchance", "match": "=>" },
            { "include": "#square-expression" },
            { "include": "#curly-expression" },
            { "include": "#operators" }
          ]
        }
      ]
    },
    "assignment-line": {
      "patterns": [
        {
          "name": "meta.assignment.perchance",
          "begin": "^(?!\\s|#|//|<)([A-Za-z_$][\\w.$-]*)(\\s*)(=)",
          "beginCaptures": {
            "1": { "name": "variable.other.assignment.perchance" },
            "3": { "name": "keyword.operator.assignment.perchance" }
          },
          "end": "$",
          "patterns": [
            { "include": "#import-special" },
            { "include": "#square-expression" },
            { "include": "#curly-expression" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#operators" },
            { "include": "#html" },
            { "include": "#variables" }
          ]
        }
      ]
    },
    "list-definition": {
      "patterns": [
        {
          "name": "meta.list.definition.perchance",
          "begin": "^(?!\\s|#|//|<|\\$)([A-Za-z_][\\w.-]*)(\\s*)(?=$|\\[|\\{|<)",
          "beginCaptures": {
            "1": { "name": "entity.name.type.list.perchance" }
          },
          "end": "$",
          "patterns": [
            { "include": "#square-expression" },
            { "include": "#curly-expression" },
            { "include": "#operators" },
            { "include": "#strings" },
            { "include": "#html" }
          ]
        }
      ]
    },
    "list-item": {
      "patterns": [
        {
          "name": "meta.list.item.perchance",
          "begin": "^(\\t| +)(?=\\S)",
          "beginCaptures": {
            "1": { "name": "punctuation.whitespace.indent.perchance" }
          },
          "end": "$",
          "patterns": [
            { "name": "constant.numeric.weight.perchance", "match": "\\b\\d+(?:\\.\\d+)?(?=\\s+\\S)" },
            { "name": "keyword.operator.probability.perchance", "match": "\\^(?:\\d+(?:\\.\\d+)?)?" },
            { "name": "keyword.control.conditional.line.perchance", "match": "\\b(?:if|else\\s+if|else)\\b" },
            { "name": "storage.type.function.arrow.perchance", "match": "=>" },
            { "include": "#import-special" },
            { "include": "#square-expression" },
            { "include": "#curly-expression" },
            { "include": "#html-script" },
            { "include": "#html" },
            { "include": "#strings" },
            { "include": "#operators" },
            { "include": "#variables" },
            { "name": "string.unquoted.list-item.perchance", "match": "[^\\[{<]+" }
          ]
        }
      ]
    },
    "square-expression": {
      "patterns": [
        {
          "name": "meta.embedded.square.perchance",
          "begin": "\\[",
          "beginCaptures": { "0": { "name": "punctuation.section.brackets.begin.perchance" } },
          "end": "\\]",
          "endCaptures": { "0": { "name": "punctuation.section.brackets.end.perchance" } },
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#operators" },
            { "include": "#function-calls" },
            { "include": "#properties" },
            { "include": "#variables" },
            { "include": "#curly-expression" }
          ]
        }
      ]
    },
    "curly-expression": {
      "patterns": [
        {
          "name": "meta.embedded.curly.perchance",
          "begin": "\\{",
          "beginCaptures": { "0": { "name": "punctuation.section.braces.begin.perchance" } },
          "end": "\\}",
          "endCaptures": { "0": { "name": "punctuation.section.braces.end.perchance" } },
          "patterns": [
            { "include": "#import-special" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#operators" },
            { "include": "#function-calls" },
            { "include": "#properties" },
            { "include": "#variables" },
            { "include": "#square-expression" }
          ]
        }
      ]
    },
    "import-special": {
      "patterns": [
        { "name": "support.function.import.perchance", "match": "\\bimport(?=\\s*:)" },
        { "name": "punctuation.separator.key-value.perchance", "match": ":" },
        { "name": "entity.name.module.perchance", "match": "(?<=import:)[^}\\s,]+" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.perchance", "begin": "\"", "end": "\"", "patterns": [{ "name": "constant.character.escape.perchance", "match": "\\\\." }] },
        { "name": "string.quoted.single.perchance", "begin": "'", "end": "'", "patterns": [{ "name": "constant.character.escape.perchance", "match": "\\\\." }] },
        { "name": "string.quoted.backtick.perchance", "begin": "`", "end": "`", "patterns": [{ "name": "constant.character.escape.perchance", "match": "\\\\." }] }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.perchance", "match": "\\b\\d+(?:\\.\\d+)?\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.conditional.perchance", "match": "\\b(if|else|return|for|while|let|const|var|function|new)\\b" },
        { "name": "constant.language.boolean.perchance", "match": "\\b(true|false|null|undefined)\\b" },
        { "name": "keyword.operator.ternary.perchance", "match": "\\?|:" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.comparison.perchance", "match": "===|!==|==|!=|<=|>=|<|>" },
        { "name": "keyword.operator.logical.perchance", "match": "&&|\\|\\||!" },
        { "name": "keyword.operator.assignment.perchance", "match": "(?<![=!<>])=(?!=)" },
        { "name": "keyword.operator.arithmetic.perchance", "match": "\\+\\+|--|\\+|-|\\*|/|%" },
        { "name": "keyword.operator.member.perchance", "match": "\\." },
        { "name": "punctuation.separator.sequence.perchance", "match": ",|;" }
      ]
    },
    "function-calls": {
      "patterns": [
        { "name": "entity.name.function.perchance", "match": "\\$?[A-Za-z_][\\w$]*(?=\\s*\\()" }
      ]
    },
    "properties": {
      "patterns": [
        { "name": "support.variable.property.perchance", "match": "(?<=\\.)[A-Za-z_][\\w$]*" }
      ]
    },
    "variables": {
      "patterns": [
        { "name": "variable.other.perchance", "match": "\\$?[A-Za-z_][\\w$]*" }
      ]
    },
    "html-script": {
      "patterns": [
        {
          "name": "meta.embedded.block.javascript",
          "begin": "(<script\\b[^>]*>)",
          "beginCaptures": { "1": { "name": "meta.tag.script.begin.html.perchance" } },
          "end": "(</script>)",
          "endCaptures": { "1": { "name": "meta.tag.script.end.html.perchance" } },
          "contentName": "source.js",
          "patterns": []
        }
      ]
    },
    "html": {
      "patterns": [
        {
          "name": "meta.tag.any.html.perchance",
          "begin": "</?[A-Za-z][^>]*",
          "end": ">",
          "patterns": [
            { "name": "entity.name.tag.html", "match": "</?[A-Za-z][A-Za-z0-9:-]*" },
            { "name": "entity.other.attribute-name.html", "match": "\\b[a-zA-Z_:][-a-zA-Z0-9_:.]*\\b(?=\\s*=)" },
            { "name": "string.quoted.double.html", "begin": "\"", "end": "\"" },
            { "name": "string.quoted.single.html", "begin": "'", "end": "'" }
          ]
        }
      ]
    }
  },
  "uuid": "7bcd1d4c-8838-44f4-93ca-7d3498c3248d"
}
