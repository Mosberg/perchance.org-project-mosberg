{
  "$schema": "https://raw.githubusercontent.com/Mosberg/perchance.org-project-mosberg/refs/heads/main/perchance.org/language/.json/tmlanguage.schema.json",
  "name": "Perchance (Mosberg Colorful v6)",
  "scopeName": "source.perchance",
  "fileTypes": ["perchance", "pch", "txt"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#hybrid-js-function-line" },
    { "include": "#hybrid-js-body" },
    { "include": "#function-definition" },
    { "include": "#assignment-line" },
    { "include": "#property-line" },
    { "include": "#list-definition" },
    { "include": "#list-item" },
    { "include": "#html-script" },
    { "include": "#html" },
    { "include": "#square-expression" },
    { "include": "#curly-expression" }
  ],
  "repository": {
    "hybrid-js-function-line": {
      "patterns": [
        {
          "name": "meta.function.definition.hybrid.perchance",
          "begin": "^(\\s*)(async\\s+)?(\\$?[A-Za-z_][\\w$]*)(\\s*)(\\()",
          "beginCaptures": {
            "2": { "name": "storage.modifier.async.perchance" },
            "3": { "name": "entity.name.function.perchance" },
            "5": { "name": "punctuation.definition.parameters.begin.perchance" }
          },
          "end": "$",
          "patterns": [
            {
              "name": "variable.parameter.perchance",
              "match": "\\b[A-Za-z_][\\w$]*\\b"
            },
            {
              "name": "punctuation.definition.parameters.end.perchance",
              "match": "\\)"
            },
            { "name": "storage.type.function.arrow.perchance", "match": "=>" }
          ]
        }
      ]
    },
    "hybrid-js-body": {
      "patterns": [
        {
          "name": "meta.embedded.block.javascript.perchance",
          "begin": "^(\\s+)(?=(?:async\\s+)?\\$?[A-Za-z_][\\w$]*\\s*\\([^\\n]*\\)\\s*=>\\s*$|(?:prompt|negative|modifiers|genre|shot|color|effect|title|description|placeholder|visible|example|label|tooltip|remember|type|default|options|instruction|onChunk|onStart|onFinish|render|startWith|outputTo|random|examples|from)\\s*\\([^\\n]*\\)\\s*=>\\s*$)",
          "end": "^(?!\\1\\s)|^(?=\\1\\S)",
          "contentName": "source.js",
          "patterns": [{ "include": "source.js" }]
        }
      ]
    },
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.perchance", "match": "^\\s*#.*$" },
        {
          "name": "comment.line.double-slash.perchance",
          "match": "^\\s*//.*$"
        },
        {
          "name": "comment.block.perchance",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "name": "meta.function.definition.perchance",
          "begin": "^(\\$[A-Za-z_][\\w$]*)(\\s*)(\\()",
          "beginCaptures": {
            "1": { "name": "entity.name.function.perchance" },
            "3": { "name": "punctuation.definition.parameters.begin.perchance" }
          },
          "end": "$",
          "patterns": [
            {
              "name": "variable.parameter.perchance",
              "match": "\\b[A-Za-z_][\\w$]*\\b"
            },
            {
              "name": "punctuation.definition.parameters.end.perchance",
              "match": "\\)"
            },
            { "name": "storage.type.function.arrow.perchance", "match": "=>" },
            { "include": "#globals" },
            { "include": "#special-identifiers" },
            { "include": "#square-expression" },
            { "include": "#curly-expression" },
            { "include": "#operators" }
          ]
        }
      ]
    },
    "assignment-line": {
      "patterns": [
        {
          "name": "meta.assignment.perchance",
          "begin": "^(?!\\s|#|//|<)([A-Za-z_$][\\w.$-]*)(\\s*)(=)",
          "beginCaptures": {
            "1": { "name": "variable.other.assignment.perchance" },
            "3": { "name": "keyword.operator.assignment.perchance" }
          },
          "end": "$",
          "patterns": [
            { "include": "#import-special" },
            { "include": "#globals" },
            { "include": "#special-identifiers" },
            { "include": "#prompt-prose" },
            { "include": "#square-expression" },
            { "include": "#curly-expression" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#operators" },
            { "include": "#html" },
            { "include": "#variables" }
          ]
        }
      ]
    },
    "property-line": {
      "patterns": [
        {
          "name": "meta.property.line.perchance",
          "begin": "^(\\s+)([A-Za-z_][\\w-]*)(:)([A-Za-z_][\\w-]*)(\\s*)(=)?",
          "beginCaptures": {
            "2": { "name": "support.type.property.namespace.perchance" },
            "3": { "name": "punctuation.separator.key-value.perchance" },
            "4": { "name": "support.type.property.name.perchance" },
            "6": { "name": "keyword.operator.assignment.perchance" }
          },
          "end": "$",
          "patterns": [
            { "include": "#globals" },
            { "include": "#special-identifiers" },
            { "include": "#prompt-prose" },
            { "include": "#square-expression" },
            { "include": "#curly-expression" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#operators" },
            { "include": "#variables" }
          ]
        },
        {
          "name": "meta.property.line.simple.perchance",
          "begin": "^(\\s+)(prompt|negative|negativePrompt|modifiers|genre|shot|color|effect|title|description|placeholder|visible|example|label|tooltip|remember|type|default|options|instruction|onChunk|onStart|onFinish|render|startWith|outputTo|introMessage|underImagesMessage|numImages|userInputs|saveTitle|resolution|examples|random|from|customEmojis)(\\s*)(=)?",
          "beginCaptures": {
            "2": { "name": "support.type.property.name.perchance" },
            "4": { "name": "keyword.operator.assignment.perchance" }
          },
          "end": "$",
          "patterns": [
            { "include": "#globals" },
            { "include": "#special-identifiers" },
            { "include": "#prompt-prose" },
            { "include": "#square-expression" },
            { "include": "#curly-expression" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#operators" },
            { "include": "#html" },
            { "include": "#variables" }
          ]
        }
      ]
    },
    "list-definition": {
      "patterns": [
        {
          "name": "meta.list.definition.perchance",
          "begin": "^(?!\\s|#|//|<|\\$)([A-Za-z_][\\w.-]*)(\\s*)(?=$|\\[|\\{|<)",
          "beginCaptures": {
            "1": { "name": "entity.name.type.list.perchance" }
          },
          "end": "$",
          "patterns": [
            { "include": "#square-expression" },
            { "include": "#curly-expression" },
            { "include": "#operators" },
            { "include": "#strings" },
            { "include": "#html" }
          ]
        }
      ]
    },
    "list-item": {
      "patterns": [
        {
          "name": "meta.list.item.perchance",
          "begin": "^(\\t| +)(?=\\S)",
          "beginCaptures": {
            "1": { "name": "punctuation.whitespace.indent.perchance" }
          },
          "end": "$",
          "patterns": [
            { "include": "#meta-keys" },
            { "include": "#hierarchy-keys" },
            {
              "name": "constant.numeric.weight.perchance",
              "match": "\\b\\d+(?:\\.\\d+)?(?=\\s+\\S)"
            },
            {
              "name": "keyword.operator.probability.perchance",
              "match": "\\^(?:\\d+(?:\\.\\d+)?)?"
            },
            {
              "name": "keyword.control.conditional.line.perchance",
              "match": "\\b(?:if|else\\s+if|else)\\b"
            },
            { "name": "storage.type.function.arrow.perchance", "match": "=>" },
            { "include": "#import-special" },
            { "include": "#globals" },
            { "include": "#special-identifiers" },
            { "include": "#prompt-prose" },
            { "include": "#square-expression" },
            { "include": "#curly-expression" },
            { "include": "#html-script" },
            { "include": "#html" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#operators" },
            { "include": "#variables" },
            { "include": "#html-entities" },
            {
              "name": "string.unquoted.list-item.perchance",
              "match": "[^\\[{<^]+"
            }
          ]
        }
      ]
    },
    "hierarchy-keys": {
      "patterns": [
        {
          "name": "entity.name.section.hierarchy.perchance",
          "match": "^(\\s{2,})([A-Za-z_][\\w-]*)(?=\\s*$)"
        }
      ]
    },
    "meta-keys": {
      "patterns": [
        {
          "name": "meta.property.key.perchance",
          "match": "\\b([A-Za-z_][\\w-]*)(:)([A-Za-z_][\\w-]*)\\b",
          "captures": {
            "1": { "name": "support.type.property.namespace.perchance" },
            "2": { "name": "punctuation.separator.key-value.perchance" },
            "3": { "name": "support.type.property.name.perchance" }
          }
        }
      ]
    },
    "square-expression": {
      "patterns": [
        {
          "name": "meta.embedded.square.perchance",
          "begin": "\\[",
          "beginCaptures": {
            "0": { "name": "punctuation.section.brackets.begin.perchance" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.section.brackets.end.perchance" }
          },
          "patterns": [
            { "include": "#import-special" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#operators" },
            { "include": "#globals" },
            { "include": "#special-identifiers" },
            { "include": "#json-keys" },
            { "include": "#function-calls" },
            { "include": "#properties" },
            { "include": "#variables" },
            { "include": "#curly-expression" }
          ]
        }
      ]
    },
    "curly-expression": {
      "patterns": [
        {
          "name": "meta.embedded.curly.perchance",
          "begin": "\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.section.braces.begin.perchance" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.end.perchance" }
          },
          "patterns": [
            { "include": "#import-special" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#operators" },
            { "include": "#globals" },
            { "include": "#special-identifiers" },
            { "include": "#json-keys" },
            { "include": "#function-calls" },
            { "include": "#properties" },
            { "include": "#variables" },
            { "include": "#square-expression" }
          ]
        }
      ]
    },
    "json-keys": {
      "patterns": [
        {
          "name": "support.type.property.json.perchance",
          "match": "(?<=[{,]\\s*)([A-Za-z_][\\w-]*)(?=\\s*:)"
        }
      ]
    },
    "globals": {
      "patterns": [
        {
          "name": "variable.language.input.perchance",
          "match": "\\binput(?=\\.)"
        },
        {
          "name": "variable.language.settings.perchance",
          "match": "\\bsettings(?=\\.)"
        },
        {
          "name": "variable.language.window.perchance",
          "match": "\\bwindow(?=\\.)"
        },
        {
          "name": "variable.language.page.perchance",
          "match": "\\bpage(?=\\.)"
        },
        {
          "name": "variable.other.memberchain.input.perchance",
          "match": "\\binput\\.[A-Za-z_][\\w$]*(?:\\.[A-Za-z_][\\w$]*)*"
        },
        {
          "name": "variable.other.memberchain.settings.perchance",
          "match": "\\bsettings\\.[A-Za-z_][\\w$]*(?:\\.[A-Za-z_][\\w$]*)*"
        },
        {
          "name": "variable.other.memberchain.window.perchance",
          "match": "\\bwindow\\.[A-Za-z_][\\w$]*(?:\\.[A-Za-z_][\\w$]*)*"
        },
        {
          "name": "variable.other.memberchain.page.perchance",
          "match": "\\bpage\\.[A-Za-z_][\\w$]*(?:\\.[A-Za-z_][\\w$]*)*"
        }
      ]
    },
    "special-identifiers": {
      "patterns": [
        {
          "name": "support.function.perchance.method.perchance",
          "match": "\\b(selectOne|selectMany|selectUnique|evaluateItem|joinItems|getLengthItems|getParent|getName|getChildren|randomize|shuffle|map|filter|reduce|splitItems|repeat|contains|startsWith|endsWith|replaceItems|sortItems|joinWith|toUpperCase|toLowerCase|trim|slice|substring|getRandomItem|getKeys|getValues)\\b(?=\\s*\\()"
        },
        {
          "name": "storage.type.perchance.keyword.perchance",
          "match": "\\b(consumableList|hierarchicalList|importedList|output|settings|page|modes|messages|prompt|negative|negativePrompt|modifiers|visible|label|description|placeholder|remember|options|instruction|onChunk|onStart|onFinish|render|startWith|outputTo|resolution|saveTitle|userInputs|numImages)\\b"
        },
        {
          "name": "support.class.dom.perchance",
          "match": "\\b(document|localStorage|sessionStorage|navigator|console|JSON|Math|Date|Array|Object|Promise|fetch|setTimeout|setInterval|clearTimeout|clearInterval|URL|Blob|CompressionStream|RegExp)\\b"
        },
        {
          "name": "support.type.dom-event.perchance",
          "match": "\\b(click|input|change|submit|keydown|keyup|load|scroll|resize|fullscreenchange|pointerdown|pointerup)\\b"
        },
        {
          "name": "support.constant.ui.perchance",
          "match": "\\b(responseEl|inputTextEl|generateBtn|continueBtn|bottomContinueBtn|retryBtn|stopBtn|bottomStopBtn|loaderEl|responseDeleteBtn|responseCopyBtn|selectedInstructionEl)\\b"
        },
        {
          "name": "support.constant.storage.perchance",
          "match": "\\b(appState|pendingObj|loadingModal|colorScheme|shareUrl|urlHashData|jsonString|blob|compressedBlob|fileName|characterName)\\b"
        },
        {
          "name": "support.variable.state.perchance",
          "match": "\\b(currentChatId|messageId|chatId|characterId|userMessage|assistantMessage|systemPrompt|apiKey|model|temperature|maxTokens|stopSequence|role|content|messages|history|memory|persona|scenario|instruction|rewriteStyle|rewriteMode|codeLanguage|promptPrefix|promptSuffix)\\b"
        },
        {
          "name": "support.function.ai.perchance",
          "match": "\\b(generate|rewrite|convert|chat|complete|stream|sendMessage|appendMessage|renderMessage|resetChat|loadCharacter|saveSettings)\\b(?=\\s*\\()"
        }
      ]
    },
    "prompt-prose": {
      "patterns": [
        {
          "name": "meta.prompt.prose.perchance",
          "begin": "(?:(?<=\\=)|(?<=^\\s{2,}prompt\\s=)|(?<=^\\s{2,}prompt\\s)|(?<=^\\s{2,}description\\s=)|(?<=^\\s{2,}description\\s)|(?<=^\\s{2,}placeholder\\s=)|(?<=^\\s{2,}placeholder\\s))\\s*",
          "end": "(?=\\s\\^(?:\\d+(?:\\.\\d+)?)?\\s*$)|$",
          "patterns": [
            { "include": "#square-expression" },
            { "include": "#globals" },
            { "include": "#special-identifiers" },
            { "include": "#strings" },
            { "include": "#html-entities" },
            {
              "name": "string.unquoted.prompt.perchance",
              "match": "[^\\[^\\n]+"
            }
          ]
        },
        {
          "name": "meta.prompt.weight.perchance",
          "match": "\\s(\\^)(\\d+(?:\\.\\d+)?)\\s*$",
          "captures": {
            "1": { "name": "keyword.operator.probability.perchance" },
            "2": { "name": "constant.numeric.perchance" }
          }
        }
      ]
    },
    "import-special": {
      "patterns": [
        {
          "name": "support.function.import.perchance",
          "match": "\\bimport(?=\\s*:)"
        },
        { "name": "punctuation.separator.key-value.perchance", "match": ":" },
        {
          "name": "entity.name.module.perchance",
          "match": "(?<=import:)[^}\\s,]+"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.regexp.perchance",
          "begin": "/(?=(?:\\\\.|[^/\\n])+/[gimsuy]*)",
          "end": "/[gimsuy]*",
          "patterns": [
            { "name": "constant.character.escape.perchance", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.backtick.perchance",
          "begin": "`",
          "end": "`",
          "patterns": [
            { "name": "constant.character.escape.perchance", "match": "\\\\." },
            {
              "name": "meta.template.expression.perchance",
              "begin": "\\\\$\\\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.section.embedded.begin.perchance" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.section.embedded.end.perchance" }
              },
              "patterns": [
                { "include": "#import-special" },
                { "include": "#strings" },
                { "include": "#numbers" },
                { "include": "#keywords" },
                { "include": "#operators" },
                { "include": "#globals" },
                { "include": "#special-identifiers" },
                { "include": "#function-calls" },
                { "include": "#properties" },
                { "include": "#variables" },
                { "include": "#curly-expression" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.double.perchance",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.perchance", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.perchance",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.perchance", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.perchance",
          "match": "\\b0[xX][0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.binary.perchance",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.perchance",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.perchance",
          "match": "\\b(if|else|switch|case|default|return|for|while|do|break|continue|try|catch|finally|throw)\\b"
        },
        {
          "name": "storage.type.perchance",
          "match": "\\b(let|const|var|function|class|extends|new|typeof|instanceof|delete|in|of|await|async)\\b"
        },
        {
          "name": "constant.language.boolean.perchance",
          "match": "\\b(true|false|null|undefined|NaN|Infinity)\\b"
        },
        { "name": "keyword.operator.ternary.perchance", "match": "\\?|:" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.arrow.perchance", "match": "=>|->" },
        { "name": "keyword.operator.choice.perchance", "match": "\\|" },
        {
          "name": "keyword.operator.range.perchance",
          "match": "\\{\\d+(?:-\\d+)?\\}"
        },
        {
          "name": "keyword.operator.repeat.perchance",
          "match": "\\*\\d+|\\?\\d+|\\^\\d+(?:\\.\\d+)?"
        },
        { "name": "keyword.operator.spread.perchance", "match": "\\.\\.\\." },
        { "name": "keyword.operator.coalescing.perchance", "match": "\\?\\?" },
        { "name": "keyword.operator.optional.perchance", "match": "\\?\\." },
        { "name": "punctuation.accessor.optional.perchance", "match": "\\?" },
        {
          "name": "keyword.operator.comparison.perchance",
          "match": "===|!==|==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.perchance",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.compound.perchance",
          "match": "\\+=|-=|\\*=|/=|%=|&&=|\\|\\|=|\\?\\?="
        },
        {
          "name": "keyword.operator.assignment.perchance",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.perchance",
          "match": "\\+\\+|--|\\+|-|\\*|/|%"
        },
        { "name": "keyword.operator.member.perchance", "match": "\\." },
        { "name": "punctuation.separator.sequence.perchance", "match": ",|;" }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.perchance",
          "match": "\\$?[A-Za-z_][\\w$]*(?=\\s*\\()"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "support.variable.property.perchance",
          "match": "(?<=\\.)[A-Za-z_][\\w$]*"
        }
      ]
    },
    "variables": {
      "patterns": [
        { "name": "variable.language.this.perchance", "match": "\\bthis\\b" },
        {
          "name": "variable.language.arguments.perchance",
          "match": "\\barguments\\b"
        },
        { "name": "variable.other.perchance", "match": "\\$?[A-Za-z_][\\w$]*" }
      ]
    },
    "html-entities": {
      "patterns": [
        {
          "name": "constant.character.entity.html.perchance",
          "match": "&(?:[A-Za-z][A-Za-z0-9]+|#\\d+|#x[0-9A-Fa-f]+);"
        }
      ]
    },
    "html-script": {
      "patterns": [
        {
          "name": "meta.embedded.block.javascript.perchance",
          "begin": "(<script\\b[^>]*>)",
          "beginCaptures": {
            "1": { "name": "meta.tag.script.begin.html.perchance" }
          },
          "end": "(</script>)",
          "endCaptures": {
            "1": { "name": "meta.tag.script.end.html.perchance" }
          },
          "contentName": "source.js",
          "patterns": [{ "include": "source.js" }]
        }
      ]
    },
    "css-inline": {
      "patterns": [
        {
          "name": "meta.attribute.style.inline.perchance",
          "begin": "\\b(style)(\\s*=\\s*)\"",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.style.html" },
            "2": { "name": "keyword.operator.assignment.html" }
          },
          "end": "\"",
          "patterns": [{ "include": "#css-value-tokens" }]
        },
        {
          "name": "meta.attribute.style.inline.perchance",
          "begin": "\\b(style)(\\s*=\\s*)'",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.style.html" },
            "2": { "name": "keyword.operator.assignment.html" }
          },
          "end": "'",
